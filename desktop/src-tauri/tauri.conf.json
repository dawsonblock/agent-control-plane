{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACP Desktop",
  "version": "0.7.1",
  "identifier": "com.acp.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8000/ui/",
    "beforeBuildCommand": "",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Control Plane",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
