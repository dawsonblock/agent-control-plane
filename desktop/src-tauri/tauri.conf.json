{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACP Desktop",
  "version": "0.8.0",
  "identifier": "com.acp.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8000/ui/",
    "beforeBuildCommand": "",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Control Plane",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null,
      "exceptionDomain": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/dawsonblock/agent-control-plane/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_PUBKEY_FROM_TAURI_SIGNER_GENERATE",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
